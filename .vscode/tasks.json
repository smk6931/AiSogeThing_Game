{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend Dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}/front"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Backend Dev",
      "type": "shell",
      "command": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "8100", "--reload"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}/back"
      },
      "problemMatcher": []
    }
  ]
}
